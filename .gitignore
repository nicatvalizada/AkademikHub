tmp/
temp/
.tmp/
*.pid
*.seed

# Local databases and dumps
*.sqlite
*.sqlite3
*.db
dump/
*.bson
*.archive

# Private keys/certificates must never be committed.
*.pem
*.key
*.p12
*.pfx
*.crt
